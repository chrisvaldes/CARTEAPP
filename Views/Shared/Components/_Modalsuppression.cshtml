@*
    Modal alert de suppression
*@

<div class="swal2-container swal2-center swal2-backdrop-show  modal" id="openAlertParameter" style="overflow-y: auto;">
    <div aria-labelledby="swal2-title" aria-describedby="swal2-html-container"
         class="swal2-popup swal2-modal swal2-icon-warning swal2-show modal-content" tabindex="-1" role="dialog" aria-live="assertive"
         aria-modal="true" style="display: grid;">

        <div class="d-flex align-items-center justify-content-center">
            <div>
                <ul class="swal2-progress-steps" style="display: none;"></ul>
                <div class="swal2-icon swal2-danger swal2-icon-show d-flex align-items-center justify-content-center" style="width:80px; height:80px; border: solid 5px red; border-radius:50%">
                    <div class="swal2-icon-content" style="color:red">?</div>
                </div>
                <img class="swal2-image" style="display: none;">
                <div class="d-flex align-items-center justify-content-center">
                    <div>
                        <div class="d-flex align-items-center justify-content-center">
                            <h2 class="swal2-title" id="swal2-title" style="display: block;">Êtes vous sûre?</h2>
                        </div>
                        <div class="swal2-html-container" id="swal2-html-container" style="display: block;">
                            De vouloir supprimer?
                        </div>
                    </div>
                </div>
            </div>
        </div>


        <div class="swal2-actions" style="display: flex;">
            <button type="button" class="swal2-cancel btn btn-danger cancelBtn"
                    aria-label="" style="display: inline-block;">
                Non, annuler!
            </button>
            
            <button type="button" id="deleteProfilBtn"
                    class="swal2-confirm btn btn-success ms-2" aria-label="" style="display: inline-block;" data-id="">
                Oui, Supprimer!
            </button>
            <div class="swal2-loader"></div>
        </div>
        <div class="swal2-footer" style="display: none;"></div>
        <div class="swal2-timer-progress-bar-container">
            <div class="swal2-timer-progress-bar" style="display: none;"></div>
        </div>
    </div>
</div>